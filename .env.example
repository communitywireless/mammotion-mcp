# mammotion-mcp configuration
# Copy to .env and fill in values for your deployment tier.

# Home Assistant endpoint (Thor1 prod HA is shared by sandbox + production tiers today)
HA_URL=http://192.168.1.201:8123

# HA long-lived bearer token (REQUIRED)
# Sandbox tier: read from /opt/infrastructure/services/ha-mcp/.env on Thor1 (canonical transient-PM path)
# Future: from gwf-creds.services.home_assistant.long_lived_token once vault is provisioned
HA_TOKEN=

# Mower entity ID in HA
MOWER_ENTITY_ID=lawn_mower.luba2_awd_1

# Area mapping JSON path (baked into image at /app/data/area-mapping.json)
AREA_MAPPING_PATH=/app/data/area-mapping.json

# Tier-4 diagnostic tools (manual_drive, goto_coord, reload_integration, etc.)
# Default false — set true on sandbox tier ONLY during dev / debug
ENABLE_DIAGNOSTIC_TOOLS=false

# Quiet hours — refuse to start mow between these times (HST hours, 0-23)
QUIET_HOURS_START_HST=21
QUIET_HOURS_END_HST=8

# Pre-flight battery minimum percentage (refuse start_mow below this)
MIN_BATTERY_PCT=30

# Concurrent-call lock file path
LOCK_FILE_PATH=/tmp/mammotion-mcp.lock

# Logging
LOG_LEVEL=INFO
